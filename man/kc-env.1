.TH "KC" "1" "Jan 0001" "kc dev" "kc Manual"

.SH NAME
kc-env - Print shell export statements for all secrets in the active vault


.SH SYNOPSIS
\fBkc env [flags]\fP


.SH DESCRIPTION
Print shell export statements for all secrets in the active vault


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for env


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--vault\fP=""
	target vault (overrides active vault)


.SH SEE ALSO
\fBkc(1)\fP
